{
  "name": "xianxia-rpg",
  "version": "0.1.0",
  "description": "凡人修仙传 - AI文字对话角色扮演游戏",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:web\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:renderer": "npm run dev:web",
    "dev:vite": "npm run dev:web",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:shared": "npm --workspace @xianxia-rpg/shared run build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:renderer": "npm run build:web",
    "build": "npm run build:shared && npm run build:main && npm run build:web",
    "start": "npm run build && electron .",
    "typecheck": "npm --workspace @xianxia-rpg/shared run typecheck && npm --workspace @xianxia-rpg/web run typecheck && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "rpg",
    "ai",
    "xianxia"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint-react/eslint-plugin": "^5.8.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": "eslint --fix"
  }
}
