{
  "name": "xianxia-rpg",
  "version": "0.1.0",
  "description": "凡人修仙传 - AI文字对话角色扮演游戏",
  "packageManager": "pnpm@10.29.3",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "pnpm run build:model && concurrently -k \"pnpm run dev:api\" \"cross-env VITE_API_BASE_URL=http://127.0.0.1:3000 pnpm run dev:web\" \"wait-on http://127.0.0.1:5173 http://127.0.0.1:3000/ai/config && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:api": "pnpm --filter @xianxia-rpg/api run dev",
    "dev:web": "pnpm --filter @xianxia-rpg/web run dev",
    "dev:renderer": "pnpm run dev:web",
    "dev:vite": "pnpm run dev:web",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:model": "pnpm --filter @xianxia-rpg/model run build",
    "build:core": "pnpm --filter @xianxia-rpg/core run build",
    "build:api": "pnpm --filter @xianxia-rpg/api run build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:web": "pnpm --filter @xianxia-rpg/web run build",
    "build:renderer": "pnpm run build:web",
    "build": "pnpm run build:model && pnpm run build:core && pnpm run build:main && pnpm run build:web && pnpm run build:api",
    "start:api": "pnpm --filter @xianxia-rpg/api run start",
    "start": "pnpm run build && electron .",
    "test:themes": "pnpm exec vitest run packages/web/src/domain/__test__/theme.test.ts",
    "typecheck": "pnpm run build:model && pnpm run build:core && pnpm --filter @xianxia-rpg/model run typecheck && pnpm --filter @xianxia-rpg/core run typecheck && pnpm --filter @xianxia-rpg/web run typecheck && pnpm --filter @xianxia-rpg/api run typecheck && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "rpg",
    "ai",
    "xianxia"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint-react/eslint-plugin": "^5.8.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^8.0.14",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@xianxia-rpg/core": "workspace:*",
    "@xianxia-rpg/model": "workspace:*"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": "eslint --fix"
  }
}
